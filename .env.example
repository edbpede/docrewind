# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Example environment for the PR-review CLI (tools/pr-review). Copy to `.env`
# (gitignored) and fill in real values for local dry-runs. NEVER commit secrets.
#
#   REVIEW_DRY_RUN=true bun run tools/pr-review/main.ts --pr <number>

# --- Required secrets --------------------------------------------------------
# NanoGPT API key (OpenAI-compatible). https://nano-gpt.com
NANOGPT_API_KEY=
# GitHub token. In Actions this is the provided GITHUB_TOKEN; locally use a
# fine-grained PAT with contents:read + pull-requests:write. Never commit it.
GITHUB_TOKEN=

# --- Target (usually injected by the workflow event) -------------------------
# owner/repo, e.g. edbpede/docrewind
# GITHUB_REPOSITORY=
# PR number to review (or pass --pr <n> on the CLI)
# PR_NUMBER=

# --- Optional review tuning (defaults shown) ---------------------------------
# Tiered model priority: primary first, then ordered fallbacks. The CLI tries
# each in order at request time; there is no separate default substitution.
# REVIEW_MODEL=deepseek/deepseek-v4-pro-cheaper:thinking
# REVIEW_FALLBACK_MODELS=xiaomi/mimo-v2.5-pro:thinking,minimax/minimax-m3:thinking
# REVIEW_MIN_CONFIDENCE=0.75
# REVIEW_MAX_COMMENTS=5
# REVIEW_DRY_RUN=false
# REVIEW_DEBUG=false
# REVIEW_ALLOW_SUGGESTIONS=false
# REVIEW_EXCLUDED_PATHS=
# REVIEW_INCLUDED_PATHS=
# REVIEW_CUSTOM_GUIDELINES=

# --- Shared review policy defaults (tools/pr-review/policy.ts) ---------------
# The workflow mirrors these trigger/association defaults and tests guard drift.
# REVIEW_ON_DRAFT=false
# REVIEW_TRIGGER_COMMAND=/review
# REVIEW_ALLOWED_ASSOCIATIONS=OWNER,MEMBER,COLLABORATOR
