{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nanogpt": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NanoGPT",
      "options": {
        "baseURL": "https://nano-gpt.com/api/v1",
        "apiKey": "{env:NANOGPT_API_KEY}"
      },
      "models": {
        "minimax/minimax-m3:thinking": {
          "name": "MiniMax M3 Thinking",
          "limit": {
            "context": 200000,
            "output": 32000
          }
        }
      }
    }
  },
  "agent": {
    "review": {
      "description": "PR code reviewer: high-confidence, comment-only, inline line-anchored comments",
      "mode": "primary",
      "model": "nanogpt/minimax/minimax-m3:thinking",
      "prompt": "{file:./.github/opencode/review-prompt.md}",
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    }
  }
}
