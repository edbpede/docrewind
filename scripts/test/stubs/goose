#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Stub `goose` for the two-lane review.sh tests. Resolves the stage from the
# --recipe path and emits the matching fixture, so one stub serves all three
# clean-context stages.
#
#   STUB_GOOSE_LOG    : append "stage=<s> recipe=<r> model=<m>" per invocation
#   STUB_FAIL_STAGES  : space-separated stage tokens forced to fail every tier
#                       (code-review | architect | synth) — for partial-lane /
#                       synthesizer-fallback tests
#   STUB_FAIL_MODELS  : space-separated model ids that exit non-zero (tier test)
#   STUB_HOST_FAIL=1  : failing tiers emit a host/route 4xx signature on stderr
#   STUB_CODE_OUT / STUB_ARCH_OUT / STUB_SYNTH_OUT : fixture path per stage
recipe=""; model="${GOOSE_MODEL:-}"; params=""
prev=""
for a in "$@"; do
  case "$prev" in
    --recipe) recipe="$a" ;;
    --model)  model="$a" ;;
    --params) params="$a" ;;
  esac
  prev="$a"
done
model="${model:-unknown}"

case "$recipe" in
  *code-review*) stage="code-review"; out="${STUB_CODE_OUT:-}" ;;
  *architect*)   stage="architect";   out="${STUB_ARCH_OUT:-}" ;;
  *synthesize*)  stage="synth";       out="${STUB_SYNTH_OUT:-}" ;;
  *)             stage="unknown";     out="" ;;
esac

[ -n "${STUB_GOOSE_LOG:-}" ] && echo "stage=$stage recipe=$recipe model=$model params=$params" >> "$STUB_GOOSE_LOG"

# Forced whole-stage failure (every tier) — exercises partial-lane + fallback.
case " ${STUB_FAIL_STAGES:-} " in
  *" $stage "*) echo "stub goose: forced failure for stage=$stage" >&2; exit 1 ;;
esac

# Per-model tier failure — exercises the tiered fallback loop.
case " ${STUB_FAIL_MODELS:-} " in
  *" $model "*)
    if [ "${STUB_HOST_FAIL:-0}" = "1" ]; then
      echo "error sending request for url (https://nano-gpt.com/api/v1/chat/completions): 404 no route" >&2
    else
      echo "stub goose: simulated transient failure for $model" >&2
    fi
    exit 1 ;;
esac

if [ -n "$out" ] && [ -f "$out" ]; then
  cat "$out"
  exit 0
fi
echo "stub goose: no STUB_*_OUT fixture for stage=$stage" >&2
exit 1
