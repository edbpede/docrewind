# Stub `goose` for review.sh tests. Reads the model from the --model flag (how
# review.sh passes it for recipe runs), falling back to GOOSE_MODEL. Behaviour:
#   STUB_FAIL_MODELS : space-separated model ids that should exit non-zero
#   STUB_HOST_FAIL=1 : failing models emit a host/route 4xx signature on stderr
#   STUB_GOOSE_OUT   : path to a file whose contents are written to stdout on success
model="${GOOSE_MODEL:-}"
prev=""
for a in "$@"; do
  [ "$prev" = "--model" ] && model="$a"
  prev="$a"
done
model="${model:-unknown}"
case " ${STUB_FAIL_MODELS:-} " in
  *" $model "*)
    if [ "${STUB_HOST_FAIL:-0}" = "1" ]; then
      echo "error sending request for url (https://nano-gpt.com/api/v1/chat/completions): 404 no route" >&2
    else
      echo "stub goose: simulated transient failure for $model" >&2
    fi
    exit 1
    ;;
esac
out="${STUB_GOOSE_OUT:-}"
if [ -n "$out" ] && [ -f "$out" ]; then
  cat "$out"
  exit 0
fi
echo "stub goose: STUB_GOOSE_OUT unset or missing" >&2
exit 1
