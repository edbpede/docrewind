#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Stub `privatebin` for the two-lane review.sh transcript test. Consumes the
# real CLI's flags (--config/--bin/create/--expire/--formatter), reads the
# transcript on stdin, and emits a paste URL exactly like the default (non-json)
# `create` output. No network.
#
#   STUB_PB_RECORD : copy stdin (the full transcript) here for assertions
#   STUB_PB_FAIL=1 : exit non-zero (simulate an upload failure -> graceful degrade)
#   STUB_PB_URL    : URL to print (default a logs.notifiarr.com-style paste link)
cat > "${STUB_PB_RECORD:-/dev/null}"
if [ "${STUB_PB_FAIL:-0}" = "1" ]; then
  echo "stub privatebin: forced upload failure" >&2
  exit 1
fi
echo "${STUB_PB_URL:-https://logs.notifiarr.com/?abc123def#StUbDeCrYpTiOnKeY}"
exit 0
