#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Stub `gh` for review.sh posting tests. Simulates `gh api --method POST .../reviews`.
#   STUB_GH_STATE      : counter file (per-test)               default /tmp/stub_gh_state
#   STUB_GH_RECORD     : last --input payload is copied here    default /tmp/stub_gh_record.json
#   STUB_GH_FAIL_ONCE=1: first call returns a 422 on stderr, then succeeds
#   STUB_GH_STRUCTURED=1: the 422 names the offender in .errors[] (targeted-drop path)
#   STUB_GH_BADPATH / STUB_GH_BADLINE : the offender named when structured
infile=""; prev=""
for a in "$@"; do
  [ "$prev" = "--input" ] && infile="$a"
  prev="$a"
done
state="${STUB_GH_STATE:-/tmp/stub_gh_state}"
record="${STUB_GH_RECORD:-/tmp/stub_gh_record.json}"
n=0; [ -f "$state" ] && n=$(cat "$state" 2>/dev/null || echo 0)
n=$((n + 1)); echo "$n" > "$state"
if [ -n "$infile" ] && [ -f "$infile" ]; then cp "$infile" "$record" 2>/dev/null || true; fi
if [ "${STUB_GH_FAIL_ONCE:-0}" = "1" ] && [ "$n" -eq 1 ]; then
  if [ "${STUB_GH_STRUCTURED:-0}" = "1" ]; then
    printf '{"message":"Validation Failed","errors":[{"resource":"PullRequestReviewComment","path":"%s","line":%s,"code":"invalid"}]}\n' \
      "${STUB_GH_BADPATH:-src/a.ts}" "${STUB_GH_BADLINE:-2}" >&2
  else
    printf '{"message":"Unprocessable Entity"}\n' >&2
  fi
  exit 1
fi
printf '{"id":999,"state":"COMMENTED"}\n'
exit 0
