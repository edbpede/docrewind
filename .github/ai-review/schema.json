        "additionalProperties": false,
        "required": ["path", "line", "side", "body", "suggestion"],
        "properties": {
          "path": { "type": "string" },
          "line": { "type": "integer" },
          "side": { "type": "string", "enum": ["RIGHT", "LEFT"] },
          "body": { "type": "string" },
          "suggestion": { "type": ["string", "null"] }
        }
      }
    }
  }
}
