{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["@types/chrome", "@types/bun"],
    "noEmit": true,
    "skipLibCheck": true,
    "paths": { "@/*": ["./*"] }
  },
  // The WXT base sets `include: ["../**/*"]`, which would otherwise pull the
  // PR-review CLI (tools/pr-review) into the whole-project `tsc`. That CLI is a
  // plain Bun program (no SolidJS JSX, no @types/chrome) with its own
  // tsconfig + `compile:pr-review` check, so exclude it here.
  "exclude": ["tools"]
}
